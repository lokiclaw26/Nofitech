+    def _compute_threshold_tokens(self, context_length: int) -> int:
+        """Effective threshold = min(percent-based, per-session cap).
+
+        MC-SESSION-BUDGET-1: when a per-session ``auto_compress_at_tokens`` is
+        configured, compress at the smaller of the two — i.e. earlier. The
+        existing percentage threshold is preserved as a floor.
+        """
+        pct_based = max(
+            int(context_length * self.threshold_percent),
+            MINIMUM_CONTEXT_LENGTH,
+        )
+        cap = getattr(self, "per_session_auto_compress_at_tokens", 0) or 0
+        if cap > 0:
+            return min(pct_based, cap)
+        return pct_based
