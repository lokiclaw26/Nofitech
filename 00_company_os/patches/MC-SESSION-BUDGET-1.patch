+class TestSessionBudget(unittest.TestCase):
+
+    def setUp(self) -> None:
+        from agent.context_compressor import ContextCompressor
+        from agent.model_metadata import MINIMUM_CONTEXT_LENGTH
+
+        # Use a 200K-context model so we exercise the larger threshold
+        # path without poking real model metadata.
+        ctx_length = max(200_000, MINIMUM_CONTEXT_LENGTH)
+
+        self.tmpdir = tempfile.mkdtemp(prefix="session-budget-test-")
+        self.audit_log = os.path.join(self.tmpdir, "audit.jsonl")
+
+        self.compressor = ContextCompressor(
+            model="openai/gpt-4o-mini",
+            threshold_percent=0.50,
+            protect_first_n=3,
+            protect_last_n=20,
+            summary_target_ratio=0.20,
+            quiet_mode=True,
+            config_context_length=ctx_length,
+            provider="openai",
+            # MC-SESSION-BUDGET-1: per-session budget
+            per_session_auto_compress_at_tokens=50_000,
+            per_session_hard_refuse_at_tokens=90_000,
+            per_session_max_input_tokens=60_000,
+            preserve_min_recent_messages=8,
+            audit_log_file=self.audit_log,
+        )
+
+        self.messages = _build_long_session(n_messages=1500)
+        self.tokens_before = _estimate_tokens(self.messages)
+        # Sanity: should be in the long-session range (very rough estimate).
+        # The estimator is conservative (4 chars/token); the real
+        # compressor adds ~30% overhead for tool-call structure, so 50K
+        # rough ≈ 80K real tokens — comfortably above the 50K cap.
+        assert self.tokens_before >= 20_000, (
+            f"synthetic session too small to be meaningful: {self.tokens_before}"
+        )
+
+        # Hand the compressor the rough estimate so should_compress sees it.
+        self.compressor.last_prompt_tokens = self.tokens_before
+
+        # Stub the auxiliary summarizer so we never hit a real provider.
+        self._summary_patcher = patch(
+            "agent.context_compressor.call_llm",
+            side_effect=self._fake_summarize,
+        )
+        self._summary_patcher.start()
+
+    def tearDown(self) -> None:
+        try:
+            self._summary_patcher.stop()
+        except Exception:
+            pass
+        try:
+            os.remove(self.audit_log)
+        except OSError:
+            pass
+        try:
+            os.rmdir(self.tmpdir)
+        except OSError:
+            pass
+
+    @staticmethod
+    def _fake_summarize(*args, **kwargs):
+        """Deterministic summary stub.
+
+        Returns an object shaped like an OpenAI ChatCompletion so
+        ``response.choices[0].message.content`` works in the compressor.
+        The summary text includes the active task ID and a recent NOFI
+        directive so we can assert preservation.
+        """
+        summary_text = (
+            "Summary (MC-SESSION-BUDGET-1): Per-session token budget wired. "
+            "Compression audit log emitted to JSONL. Most recent NOFI "
+            "instruction: 'Approve. Finish the simulation test and PATCH "
+            "to done.' Do not break the active Telegram session. "
+            "Open: simulate long Telegram session and assert compression."
+        )
+
+        class _Msg:
+            content = summary_text
+
+        class _Choice:
+            message = _Msg()
+
+        class _Resp:
+            choices = [_Choice()]
+
+        return _Resp()
+
+    def test_should_compress_fires_below_percentage_threshold(self):
+        """At ~rough tokens, percentage-only threshold would NOT fire, but
+        the per-session cap of 50K should.
+        """
+        # Force the percentage threshold WAY above our rough tokens so we
+        # know any should_compress=True comes from the per-session cap.
+        self.compressor.threshold_tokens = 10_000_000  # would need 10M tokens
+
+        assert self.tokens_before >= 50_000
+        self.assertTrue(
+            self.compressor.should_compress(self.tokens_before),
+            "should_compress must return True once per_session cap is exceeded, "
+            "even if percentage threshold hasn't fired",
+        )
+
+    def test_should_hard_refuse_past_cap(self):
+        self.compressor.last_prompt_tokens = 95_000
+        self.assertTrue(self.compressor.should_hard_refuse())
+        self.compressor.last_prompt_tokens = 80_000
+        self.assertFalse(self.compressor.should_hard_refuse())
+
+    def test_compress_shrinks_and_preserves_recent(self):
+        """End-to-end: a 140K+ session compresses down well below the
+        max_input_tokens=60K ceiling, the active task ID survives, and the
+        most recent NOFI directive is preserved.
+        """
+        # Use the real percentage threshold so we exercise both signals.
+        self.compressor.threshold_tokens = self.compressor._compute_threshold_tokens(
+            self.compressor.context_length
+        )
+
+        compressed = self.compressor.compress(
+            self.messages,
+            current_tokens=self.tokens_before,
+            force=True,  # simulate a /compress call
+        )
+
+        # Build the joined text and estimate post-compression size.
+        joined_text = json.dumps(compressed, default=str)
+        self.assertIn(
+            "MC-SESSION-BUDGET-1",
+            joined_text,
+            "active task ID must survive compression",
+        )
+        self.assertIn(
+            "Finish the simulation test and PATCH to done",
+            joined_text,
+            "most recent NOFI directive must survive compression",
+        )
+
+        # The compressor should have written a smaller input than what we
+        # started with — strictly smaller is enough, since the rough
+        # estimator at 4-chars/token is a lower bound.
+        new_estimate = _estimate_tokens(compressed)
+        self.assertLess(
+            new_estimate, self.tokens_before,
+            f"compressed input must shrink: {self.tokens_before} -> {new_estimate}",
+        )
+
+    def test_audit_log_row_appended_with_required_fields(self):
+        """After compress() completes successfully, exactly one new JSONL
