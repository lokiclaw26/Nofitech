+        if not log_path:
+            return  # audit disabled
+        try:
+            # Light extraction: pull task IDs (uppercase-NN style), common
+            # blocker keywords, and a short hash of the summary so we can
+            # correlate runs without dumping the whole summary to JSONL.
+            import agent.compression_audit as _audit_mod
+            _extract_task_ids = _audit_mod._extract_task_ids
+            _extract_user_prefs = _audit_mod._extract_user_prefs
+            _extract_open_blockers = _audit_mod._extract_open_blockers
+            _summary_fingerprint = _audit_mod._summary_fingerprint
+            summary_text = (
+                getattr(self, "_previous_summary", "") or ""
+            )
+            preserved_task_ids = _extract_task_ids(summary_text)
+            preserved_user_prefs = _extract_user_prefs(summary_text)
+            preserved_open_blockers = _extract_open_blockers(summary_text)
+            summary_fp = _summary_fingerprint(summary_text)
+            row = {
+                "timestamp": time.time(),
+                "session_id": getattr(self, "_audit_session_id", "") or "",
+                "agent": getattr(self, "_audit_agent", "") or "",
+                "trigger": trigger,
+                "model": getattr(self, "model", "") or "",
+                "provider": getattr(self, "provider", "") or "",
+                "tokens_before": int(tokens_before),
+                "tokens_after": int(tokens_after),
+                "messages_in": int(messages_in),
+                "messages_out": int(messages_out),
+                "summary_file": str(summary_fp),
+                "preserved_task_ids": preserved_task_ids,
+                "preserved_user_prefs": preserved_user_prefs,
+                "preserved_open_blockers": preserved_open_blockers,
+                "threshold_tokens": int(getattr(self, "threshold_tokens", 0) or 0),
+            }
+            with open(log_path, "a", encoding="utf-8") as fh:
+                fh.write(json.dumps(row, ensure_ascii=False) + "\n")
+        except Exception as exc:  # noqa: BLE001 — best-effort
+            try:
+                logger.warning("compression audit emit failed: %s", exc)
+            except Exception:
+                pass
+
