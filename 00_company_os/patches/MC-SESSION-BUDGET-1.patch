new file mode 100644
index 000000000..9ece7ea41
--- /dev/null
+++ b/tests/test_session_budget.py
@@ -0,0 +1,348 @@
+"""MC-SESSION-BUDGET-1 — long-session simulation + audit-log verification.
+
+Mimics a long-lived Telegram DM session (~150 messages, ~140K-180K input
+tokens) and confirms:
+
+  * the new per-session budget makes ``ContextCompressor.should_compress``
+    fire earlier than the percentage-only threshold,
+  * ``compress()`` shrinks the input below the configured max_input_tokens
+    ceiling while preserving the most recent NOFI instruction and the
+    active task ID,
+  * one JSONL audit row is appended with all required fields.
+
+The compressor is instantiated with ``quiet_mode=True`` and a synthetic
+API key so the test does not touch any real provider.  We monkeypatch
+``agent.auxiliary_client.call_llm`` so the summary step is a deterministic
+string instead of an actual model call — this keeps the test fast and
+hermetic while exercising the real compress() code path.
+"""
+
+from __future__ import annotations
+
+import json
+import os
+import sys
+import tempfile
+import unittest
+from pathlib import Path
+from unittest.mock import patch
+
+
+# Ensure the repo root is importable when pytest is invoked from outside.
+_REPO = Path(__file__).resolve().parent.parent
+if str(_REPO) not in sys.path:
+    sys.path.insert(0, str(_REPO))
+
+
+def _build_long_session(n_messages: int = 1500) -> list:
+    """Build a synthetic conversation the size of a long Telegram session.
+
+    The middle block is padded with realistic-looking content (a mix of
+    tool calls, agent replies, and NOFI instructions) so the message-list
+    rough-token estimate lands in the 140K-180K window the task targets.
+
+    Note: the rough estimator used in the test (``_estimate_tokens``) counts
+    ~4 chars per token, which is conservative for code/tool-call content.
+    The real :func:`agent.model_metadata.estimate_messages_tokens_rough` adds
+    ~30% overhead for tool-call structure. We size the message list so the
+    rough estimator reports >= 50K tokens, which corresponds to ~80K real
+    tokens — well above the per-session ``auto_compress_at_tokens`` cap of
+    50K and a realistic long-Telegram-session size.
+    """
+    msgs: list = []
+    msgs.append({
+        "role": "system",
+        "content": "You are Hermes Agent, a CLI AI Agent. NOFI is your owner.",
+    })
+
+    # Initial exchange — protected by protect_first_n.
+    msgs.append({"role": "user", "content": "I'm NOFI. Let's ship the MC-SESSION-BUDGET-1 work."})
+    msgs.append({
+        "role": "assistant",
+        "content": (
+            "Acknowledged. Starting MC-SESSION-BUDGET-1 — per-session token budget "
+            "and compression audit. Will keep you posted."
+        ),
+    })
+
+    pad_user = (
+        "Continue with the work. Make sure the per-session budget config keys "
+        "are validated end-to-end and remember to test the audit log emission. "
+        "Always avoid breaking the active Telegram session. From now on, also "
+        "wire up /compress to write to the JSONL audit log. " + ("filler " * 200)
+    )
+    pad_assistant = (
+        "Acknowledged. Running the next batch of edits now. "
+        "Will not touch kanban-auto-*.sh or llm_guard.py as per scope. "
+        "Working on MC-SESSION-BUDGET-1 and MC-LLM-BURN-FIX-1 in parallel. "
+        + ("detail " * 280)
+    )
+
+    # Fill the middle with realistic content — alternating user/assistant.
+    while len(msgs) < n_messages - 8:
+        msgs.append({"role": "user", "content": pad_user})
+        msgs.append({"role": "assistant", "content": pad_assistant})
+        msgs.append({
+            "role": "assistant",
+            "content": None,
+            "tool_calls": [{
+                "id": f"call_{len(msgs)}",
+                "type": "function",
+                "function": {
+                    "name": "terminal",
+                    "arguments": json.dumps({
+                        "command": "ls -la /home/nofidofi/NofiTech-Ind/00_company_os/logs/" + ("x" * 400)
+                    }),
+                },
+            }],
+        })
+        msgs.append({
+            "role": "tool",
+            "tool_call_id": f"call_{len(msgs) - 1}",
+            "content": "session-compression.jsonl\nllm-calls.jsonl\n" + ("y" * 400),
+        })
+
+    # Recent tail — must survive compression.
+    msgs.append({"role": "user", "content": "Status check — what's blocking the audit log emit?"})
+    msgs.append({
+        "role": "assistant",
+        "content": "Patched context_compressor.py to call _emit_compression_audit on success.",
+    })
+    msgs.append({"role": "user", "content": "Approve. Finish the simulation test and PATCH to done."})
+    msgs.append({
+        "role": "assistant",
+        "content": "Will do. Writing tests/test_session_budget.py now.",
+    })
+
+    return msgs
+
+
+def _estimate_tokens(messages: list) -> int:
+    """Cheap token estimate without loading the agent's estimator."""
+    chars = 0
+    for m in messages:
+        c = m.get("content")
+        if isinstance(c, str):
+            chars += len(c)
+        elif isinstance(c, list):
+            for part in c:
+                if isinstance(part, dict):
+                    chars += len(part.get("text", "") or "")
+        # Tool calls inflate token count substantially.
+        if "tool_calls" in m:
+            chars += sum(
+                len(json.dumps(tc.get("function", {}).get("arguments", "")))
+                for tc in (m.get("tool_calls") or [])
+            )
+    # ~4 chars/token is a reasonable lower-bound for English/code text.
+    return chars // 4
+
