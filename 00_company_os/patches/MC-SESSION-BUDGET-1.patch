diff --git a/agent/compression_audit.py b/agent/compression_audit.py
new file mode 100644
index 000000000..20d65c1c4
--- /dev/null
+++ b/agent/compression_audit.py
@@ -0,0 +1,172 @@
+"""MC-SESSION-BUDGET-1 — best-effort extraction of preserved facts for the
+compression audit JSONL.
+
+The audit row is emitted from :class:`agent.context_compressor.ContextCompressor`
+every time compression completes successfully. It records what was
+preserved (task IDs, recent user instructions, open blockers) so downstream
+analysis can answer "why is NOFI's Telegram session still 3.8M tokens/hour
+even though /compress is firing?"
+
+All extraction is best-effort and runs in <5ms. Failures are swallowed by
+the caller. We pull from three sources, in order of freshness:
+
+1. The compressor's in-memory previous summary (when available) — this is
+   exactly the text that survived into the tail of the compressed history.
+2. The recent tail of ``~/.hermes/sessions/<sid>.jsonl`` if readable — to
+   catch the latest user instruction if it didn't make it into the summary.
+3. Otherwise return empty lists — never raise.
+
+The module intentionally has no Hermes-wide dependencies so it can be
+imported safely from any process that loads ``ContextCompressor``.
+"""
+
+from __future__ import annotations
+
+import hashlib
+import os
+import re
+from typing import Any, Dict, List, Optional
+
+
+# Match things like ``MC-SESSION-BUDGET-1``, ``DIY-016``, ``MC-LLM-BURN-FIX-1``,
+# ``RGV1-123``. We allow optional internal hyphens so project-family IDs
+# (``MC-FOO-BAR-1``) are captured in full instead of fragmenting into the
+# trailing ``BAR-1`` token.
+_TASK_ID_RE = re.compile(
+    r"\b([A-Z][A-Z0-9]+(?:-[A-Z0-9]+)*)-([0-9]{1,4}[A-Z]?)\b"
+)
+
+# Phrases that suggest the user just gave a directive we don't want to lose
+# during compression. Captured as a tiny list — keep it cheap.
+_USER_PREF_HINTS = (
+    "remember",
+    "always",
+    "never ",
+    "don't ",
+    "do not ",
+    "from now on",
+    "going forward",
+    "i prefer",
+    "i want",
+    "make sure",
+    "no fi",
+    "nofi",
+)
+
+# Phrases that imply an open blocker or pending question — when these show
+# up in the summary we want the audit row to flag them.
+_BLOCKER_HINTS = (
+    "blocked",
+    "blocker",
+    "waiting on",
+    "awaiting",
+    "TODO",
+    "FIXME",
+    "open question",
+    "next step",
+    "pending",
+    "TODO:",
+    "in progress",
+    "running_now",
+)
+
+
+def _extract_task_ids(*sources: str) -> List[str]:
+    """Find project-style task IDs in any of the given text sources.
+
+    Dedupes while preserving first-seen order, caps at 16 entries so a
+    pathological summary can't blow up the JSONL row.
+    """
+    seen: List[str] = []
+    seen_set = set()
+    for src in sources:
+        if not src:
+            continue
+        for m in _TASK_ID_RE.finditer(src):
+            tid = f"{m.group(1)}-{m.group(2)}"
+            if tid not in seen_set:
+                seen_set.add(tid)
+                seen.append(tid)
+                if len(seen) >= 16:
+                    return seen
+    return seen
+
+
+def _extract_user_prefs(*sources: str, limit: int = 5) -> List[str]:
+    """Pull sentences that contain user-preference language.
+
+    Returns up to ``limit`` short strings — each is a single sentence,
+    trimmed, max 240 chars, so the audit row stays compact.
+    """
+    out: List[str] = []
+    out_set = set()
+    for src in sources:
+        if not src:
+            continue
+        # Cheap sentence split on `.`, `!`, `?`, newline. Good enough for
+        # log extraction; we don't need NLTK.
+        for sent in re.split(r"[.!?\n]+", src):
+            s = sent.strip()
+            if len(s) < 8 or len(s) > 240:
+                continue
+            low = s.lower()
+            if any(h in low for h in _USER_PREF_HINTS):
+                if s not in out_set:
+                    out_set.add(s)
+                    out.append(s)
+                    if len(out) >= limit:
+                        return out
+    return out
+
+
+def _extract_open_blockers(*sources: str, limit: int = 5) -> List[str]:
+    """Pull sentences that contain blocker / pending-work language."""
+    out: List[str] = []
+    out_set = set()
+    for src in sources:
+        if not src:
+            continue
+        for sent in re.split(r"[.!?\n]+", src):
+            s = sent.strip()
+            if len(s) < 4 or len(s) > 200:
+                continue
+            low = s.lower()
+            if any(h in low for h in _BLOCKER_HINTS):
+                if s not in out_set:
+                    out_set.add(s)
+                    out.append(s)
+                    if len(out) >= limit:
+                        return out
+    return out
+
+
+def _summary_fingerprint(text: str) -> str:
+    """Short stable fingerprint of a summary, suitable for cross-run correlation.
+
+    Uses the first 16 hex chars of the SHA-256 digest so we never leak the
+    summary contents into the audit log itself.
+    """
+    if not text:
+        return ""
+    h = hashlib.sha256(text.encode("utf-8", errors="ignore")).hexdigest()
+    return f"sha256:{h[:16]}"
+
+
+def collect_preserved(
+    *,
+    summary: str = "",
+    recent_tail_text: str = "",
+) -> Dict[str, Any]:
+    """Convenience: one-call helper used by tests + the audit emit.
+
+    Returns the three extraction buckets plus the summary fingerprint, all
+    bounded so the result is safe to JSON-encode straight into a log row.
+    """
+    return {
+        "preserved_task_ids": _extract_task_ids(summary, recent_tail_text),
+        "preserved_user_prefs": _extract_user_prefs(summary, recent_tail_text),
+        "preserved_open_blockers": _extract_open_blockers(
+            summary, recent_tail_text
+        ),
+        "summary_file": _summary_fingerprint(summary),
+    }
